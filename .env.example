# Google Gemini API Key (free from https://aistudio.google.com)
# Leave empty to use extractive summarization fallback
GOOGLE_GENERATIVE_AI_API_KEY=

# Slack Incoming Webhook URL for daily brief
# Setup: https://api.slack.com/apps → Create App → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Vercel Cron Secret (auto-set by Vercel)
CRON_SECRET=

# App URL (for Slack brief footer link)
NEXT_PUBLIC_APP_URL=https://fintech-pulse-india.vercel.app
